# Sunrise Rescue Receipt Form — environment configuration
# Copy this file to .env and fill in real values. Never commit .env.

# --- Web server ---
PORT=3000

# --- Email (SMTP) ---
# These are placeholders. Use the actual mail provider Sunrise Rescue uses
# (Google Workspace, Postmark, SendGrid, etc.). For Gmail/Workspace, generate
# an app password and use port 465 (SSL).
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@sunriserescue.com
SMTP_PASS=replace-with-app-password

# Visible "From" address on the receipt email
MAIL_FROM_NAME=Sunrise Rescue
MAIL_FROM_ADDRESS=info@sunriserescue.com

# Always BCC a copy of every receipt to Sunrise Rescue's records inbox
MAIL_BCC_RESCUE=info@sunriserescue.com

# --- Admin system (Sunrise Rescue's record-keeping endpoint) ---
# When a receipt is generated, the form will POST a JSON record here so it
# shows up in the Sunrise Rescue admin dashboard. If you don't have an
# endpoint yet, leave ADMIN_POST_URL blank — the form still works, it just
# skips the admin push and logs the record to ./admin-log.jsonl instead.
ADMIN_POST_URL=
ADMIN_POST_TOKEN=

# --- Branding ---
ORG_NAME=Sunrise Rescue
ORG_EIN=85-1162020
ORG_ADDRESS_LINE_1=Sunrise Rescue
ORG_ADDRESS_LINE_2=San Diego, CA
ORG_WEBSITE=https://sunriserescue.com
